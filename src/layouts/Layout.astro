---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** When true, render only the page shell (no magazine bar/footer).
   *  Used by the portfolio, which brings its own warm-gradient chrome. */
  bare?: boolean;
}
const {
  title = 'Ram Jeevan Vinod — Writer & Data Analyst',
  description = 'Essays on the art history of ancient India, short fiction, and data projects by Ram Jeevan Vinod.',
  bare = false,
} = Astro.props;

const nav = [
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/portfolio#about', label: 'About' },
  { href: '/blog', label: 'Essays' },
  { href: '/fiction', label: 'Fiction' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/main_icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600&family=Spectral:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Karla:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    {bare ? (
      <slot />
    ) : (
      <>
        <header class="bar">
          <div class="bar-inner wrap">
            <a href="/" class="logo serif">Ram Jeevan</a>
            <span class="bar-kicker kicker">Art · Culture · Heritage</span>
            <nav class="bar-nav">
              {nav.map((n) => <a href={n.href}>{n.label}</a>)}
              <a href="/blog" class="search" aria-label="Search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
              </a>
            </nav>
          </div>
        </header>

        <main>
          <slot />
        </main>

        <footer class="footer">
          <div class="pattern-band pattern-band--dark" role="presentation"></div>
          <div class="foot wrap">
            <div>
              <a href="/" class="logo serif foot-logo">Ram Jeevan</a>
              <p class="foot-bio">Essays on ancient Indian art — who made it, why so much of it went unsigned, and what it meant. From a Singapore writer and data analyst.</p>
            </div>
            <nav class="foot-links">
              <a href="/portfolio">Portfolio</a>
              <a href="/portfolio#about">About</a>
              <a href="/blog">Essays</a>
              <a href="/fiction">Fiction</a>
              <a href="#">Instagram</a>
            </nav>
          </div>
          <div class="foot-bar folio">© 2026 Ram Jeevan Vinod · Singapore</div>
        </footer>
      </>
    )}
  </body>
</html>

<style>
  .bar{position:sticky;top:0;z-index:30;background:rgba(243,236,220,.9);backdrop-filter:blur(8px);border-bottom:1px solid var(--ink)}
  .bar::after{content:"";display:block;height:2px;background:var(--red)}
  .bar-inner{display:flex;align-items:center;justify-content:space-between;padding-top:14px;padding-bottom:14px;gap:20px}
  .logo{font-style:italic;font-weight:600;font-size:1.6rem;color:var(--ink);white-space:nowrap;transition:color .25s}
  .logo:hover{color:var(--red)}
  .bar-kicker{flex:0 1 auto}
  .bar-nav{display:flex;align-items:center;gap:26px}
  .bar-nav a{font-family:var(--sans);font-weight:600;font-size:.78rem;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-soft);transition:color .2s}
  .bar-nav a:hover{color:var(--red)}
  .bar-nav a:not(.search){position:relative}
  .bar-nav a:not(.search)::after{content:"";position:absolute;left:0;bottom:-5px;width:100%;height:2px;background:var(--red);transform:scaleX(0);transform-origin:right;transition:transform .3s ease}
  .bar-nav a:not(.search):hover::after{transform:scaleX(1);transform-origin:left}
  .bar-nav .search{display:inline-flex;transition:transform .25s ease, color .2s}
  .bar-nav .search:hover{transform:rotate(90deg)}
  .bar-nav .search svg{width:17px;height:17px}

  .footer{position:relative;z-index:1;background:var(--ink);color:var(--paper)}
  .pattern-band{height:46px;background:url("/images/madhubani-pattern.png") center/auto 150px repeat-x;position:relative;z-index:1}
  .pattern-band--dark{opacity:.85;filter:saturate(.9)}
  .foot{display:grid;grid-template-columns:1.5fr 1fr;gap:40px;padding:70px 32px 40px;align-items:start}
  .foot-logo{color:#F3ECDC;font-size:2rem;margin-bottom:.5em;display:inline-block}
  .foot-bio{color:#b8a98c;max-width:460px;font-size:.96rem}
  .foot-links{display:flex;flex-direction:column;gap:13px}
  .foot-links a{font-family:var(--sans);font-weight:600;font-size:.8rem;letter-spacing:.08em;text-transform:uppercase;color:var(--paper);transition:color .2s, transform .25s ease;align-self:flex-start}
  .foot-links a:hover{color:var(--marigold);transform:translateX(5px)}
  .foot-bar{border-top:1px solid rgba(205,188,156,.16);text-align:center;padding:22px;color:#9a8a70}

  @media(max-width:960px){
    .bar-kicker{display:none}
    .foot{grid-template-columns:1fr}
  }
  @media(max-width:560px){
    .bar-nav{gap:16px}
  }
</style>
