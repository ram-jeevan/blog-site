---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => p.data.type !== 'fiction')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
---

<Layout title="Essays — Ram Jeevan Vinod" description="Essays on ancient Indian art, music, poetry and architecture and their relationship to Hindu philosophy — and the occasional reading of Singaporean culture.">
  <section class="blog wrap">
    <header class="blog-head">
      <img src="/images/warli/write.png" alt="" class="chip" />
      <div>
        <span class="kicker">The Archive</span>
        <h1 class="serif blog-title">Essays</h1>
        <p class="blog-desc serif">On ancient Indian art &amp; belief — and the occasional reading of Singaporean culture.</p>
      </div>
    </header>

    <ol class="list">
      {posts.map((p, i) => (
        <li class="row">
          <a class="row-link" href={`/blog/${p.id}`}>
            <span class="row-no folio">{String(i + 1).padStart(2, '0')}</span>
            <figure class="row-thumb">{p.data.cover && <img src={p.data.cover} alt={p.data.title} loading="lazy" />}</figure>
            <div class="row-text">
              <span class="kicker">{p.data.category}</span>
              <h2 class="serif row-title">{p.data.title}</h2>
              <p class="row-desc">{p.data.description}</p>
            </div>
            <span class="row-meta folio">{fmt(p.data.date)}<br />{p.data.readingTime}</span>
          </a>
        </li>
      ))}
    </ol>
  </section>
</Layout>

<style>
  .blog{padding:64px 32px 96px}
  .blog-head{display:flex;align-items:center;gap:22px;border-bottom:2px solid var(--ink);padding-bottom:30px;margin-bottom:8px}
  .blog-head .chip{width:60px;height:60px;border:1px solid var(--red-deep);flex:0 0 auto}
  .blog-title{font-weight:800;font-size:clamp(2.4rem,5vw,4rem);line-height:1;color:var(--ink)}
  .blog-desc{font-style:italic;font-size:1.2rem;color:var(--ink-soft);margin-top:.2em}

  .list{list-style:none}
  .row{border-bottom:1px solid var(--line)}
  .row-link{display:grid;grid-template-columns:auto 150px 1fr auto;gap:28px;align-items:center;padding:30px 0;transition:background .2s}
  .row-link:hover{background:rgba(190,58,36,.04)}
  .row-no{font-size:1rem;color:var(--red);align-self:start;padding-top:6px}
  .row-thumb{width:150px;height:104px;overflow:hidden;border:1px solid var(--ink);background:#2a211a}
  .row-thumb img{width:100%;height:100%;object-fit:cover;transition:transform .5s}
  .row-link:hover .row-thumb img{transform:scale(1.06)}
  .row-text .kicker{font-size:.66rem}
  .row-title{font-weight:600;font-size:1.7rem;line-height:1.1;margin:.18em 0 .25em;color:var(--ink);transition:color .2s}
  .row-link:hover .row-title{color:var(--red)}
  .row-desc{font-size:.98rem;color:var(--ink-soft);max-width:60ch}
  .row-meta{text-align:right;line-height:1.7;color:var(--ink-mute);white-space:nowrap}

  @media(max-width:760px){
    .row-link{grid-template-columns:1fr;gap:14px}
    .row-no,.row-meta{text-align:left}
    .row-thumb{width:100%;height:180px}
  }
</style>
