---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const edition = 'Summer 2026';
const chips = ['/images/warli/easel.png', '/images/warli/pottery.png', '/images/warli/meditate.png'];

// Dynamic homepage lineup:
//  - hero/feature = the most recent essay
//  - grid = the next most-recent essays, with the latest fiction piece always pinned
// When a new post is added everything pushes down by one; the fiction slot stays.
const all = await getCollection('blog');
const byDate = [...all].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const essays = byDate.filter((p) => p.data.type !== 'fiction');
const fictions = byDate.filter((p) => p.data.type === 'fiction');
const feature = essays[0];
const pinnedFiction = all.find((p) => p.id === 'mamas-boy') ?? fictions[0];
const firstPichvai = all.find((p) => p.id === 'pichvai-and-bhakti');
const seen = new Set();
const grid = [...essays.slice(1, 5), firstPichvai, pinnedFiction]
  .filter(Boolean)
  .filter((p) => (seen.has(p.id) ? false : seen.add(p.id)));
// top coverlines: two essays + the pinned fiction (Mama's Boy)
const contents = [grid[0], grid[1], pinnedFiction].filter(Boolean);

const metaDescription = 'Essays on ancient Indian art — painting, music, poetry, and architecture — and how it connects to Hindu belief and practice. Bhakti, instruments, ghazals, paintings. With the occasional look at Singaporean culture and identity.';

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }).toUpperCase();
const fmtYear = (d: Date) => d.getFullYear();
---

<Layout title="Ram Jeevan Vinod" description={metaDescription}>

  <!-- ============ COVER ============ -->
  <section class="cover wrap">
    <div class="cover-text">
      <span class="kicker">Celebrating tradition to appreciate today</span>
      <h1 class="masthead serif">Written<br />Works</h1>
      <p class="tagline serif">Bhakti Art History and Singaporean fiction stories.</p>

      <ul class="contents">
        {contents.map((c, i) => (
          <li>
            <img src={chips[i % chips.length]} alt="" class="chip" />
            <a href={`/blog/${c.id}`}>
              <span class="c-label">{c.data.category}</span>
              <span class="c-title serif">{c.data.title}</span>
            </a>
          </li>
        ))}
      </ul>

    </div>

    <figure class="cover-art">
      <img src="/images/hero_hanuman.jpg" alt="Hanuman, a 1973 painting by Thawan Dutchanee" />
      <figcaption class="folio">Hanuman, Thawan Dutchanee, 1973</figcaption>
    </figure>
  </section>

  <div class="pattern-band" role="presentation"></div>

  <!-- ============ FEATURE ============ -->
  <section class="feature">
    <figure class="feature-art">
      {feature.data.cover && <img src={feature.data.cover} alt={feature.data.title} />}
    </figure>
    <div class="feature-text">
      <div class="feature-running">
        <span class="kicker">Feature</span>
        <span class="folio">{edition} · No. {String(essays.length).padStart(2, '0')}</span>
      </div>
      <span class="feature-cat kicker">{feature.data.category}</span>
      <h2 class="serif feature-title">{feature.data.title}</h2>
      <div class="feature-body">
        <p>{feature.data.description}</p>
      </div>
      <p class="meta"><b>Ram Jeevan</b> &nbsp;·&nbsp; {fmt(feature.data.date)} {fmtYear(feature.data.date)} &nbsp;·&nbsp; {feature.data.readingTime}</p>
      <a href={`/blog/${feature.id}`} class="btn btn--solid">Read the essay <span>→</span></a>
      {feature.data.pull && (
        <blockquote class="feature-pull serif"><span class="qmark">“</span>{feature.data.pull}</blockquote>
      )}
    </div>
  </section>

  <!-- ============ ARCHIVE ============ -->
  <section id="archive" class="archive wrap">
    <div class="sec-head">
      <img src="/images/warli/write.png" alt="" class="chip chip--head" />
      <div>
        <span class="kicker">Selected</span>
        <h2 class="serif sec-title">In This Edition</h2>
      </div>
      <div class="rule-motif" aria-hidden="true"><span class="dot"></span></div>
    </div>

    <div class="grid">
      {grid.map((e) => (
        <a class="card" href={`/blog/${e.id}`}>
          <div class="card-img">{e.data.cover && <img src={e.data.cover} alt={e.data.title} loading="lazy" />}</div>
          <div class="card-body">
            <span class="card-cat kicker">{e.data.category}</span>
            <h3 class="serif card-title">{e.data.title}</h3>
            <p class="card-sub">{e.data.description}</p>
            <p class="card-meta folio"><span class="diamond"></span>{fmt(e.data.date)} · {e.data.readingTime}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="archive-more"><a href="/blog" class="btn">Browse all essays <span>→</span></a></div>
  </section>

  <!-- ============ PORTFOLIO CTA ============ -->
  <section class="cta">
    <div class="cta-inner wrap">
      <span class="kicker cta-kicker">Portfolio</span>
      <h2 class="serif cta-title">Stories, Data &amp; Essays</h2>
      <p class="cta-dek">More than the essays: short fiction set in Singapore, data and machine-learning projects, and criticism.</p>
      <a href="/portfolio" class="btn cta-btn">View Portfolio <span>→</span></a>
    </div>
  </section>

</Layout>

<style>
  .cover{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;padding:70px 32px 64px}
  .cover-text{animation:rise .6s ease both}
  .masthead{font-weight:800;font-size:clamp(3.4rem,8vw,6.6rem);line-height:.92;letter-spacing:-.01em;margin:.18em 0 .3em;color:var(--ink)}
  .tagline{font-style:italic;font-size:1.35rem;color:var(--ink-soft);max-width:30ch;margin-bottom:1.8em}
  .contents{list-style:none;border-top:1px solid var(--line);padding-top:18px}
  .contents li{position:relative;display:flex;gap:16px;align-items:center;padding:13px 8px 13px 0;border-bottom:1px solid var(--line-soft);transition:background .25s ease, padding-left .25s ease}
  .contents li:hover{background:rgba(190,58,36,.05);padding-left:8px}
  .contents li::after{content:"→";position:absolute;right:10px;top:50%;transform:translate(-8px,-50%);opacity:0;color:var(--red);font-family:var(--sans);transition:opacity .25s ease, transform .25s ease}
  .contents li:hover::after{opacity:1;transform:translate(0,-50%)}
  .contents li a{display:block}
  .chip{width:46px;height:46px;flex:0 0 auto;border:1px solid var(--red-deep);transition:transform .3s ease}
  .contents li:hover .chip{transform:rotate(-5deg) scale(1.08)}
  .c-label{display:block;font-family:var(--sans);font-weight:700;text-transform:uppercase;letter-spacing:.14em;font-size:.66rem;color:var(--red);margin-bottom:2px}
  .c-title{display:block;font-size:1.18rem;color:var(--ink);line-height:1.15;transition:color .2s}
  .contents li:hover .c-title{color:var(--red)}
  .cover-quote{margin-top:26px;font-style:italic;font-size:1.25rem;color:var(--ink);padding-left:6px;max-width:34ch}
  .qmark{color:var(--red);font-size:1.4em;line-height:0;margin-right:.04em;vertical-align:-.25em}
  .cover-art{position:relative;animation:rise .6s ease .15s both}
  .cover-art img{width:100%;aspect-ratio:3/4;object-fit:cover;border:1px solid var(--ink);outline:1px solid var(--ink);outline-offset:6px;transition:filter .5s ease, outline-offset .35s ease}
  .cover-art:hover img{filter:saturate(1.12) contrast(1.03);outline-offset:9px}
  .cover-art figcaption{margin-top:18px;text-align:right;transition:color .3s}
  .cover-art:hover figcaption{color:var(--red)}

  .pattern-band{height:62px;background:url("/images/madhubani-pattern.png") center/auto 150px repeat-x;border-top:1px solid var(--line);border-bottom:1px solid var(--line);opacity:.9;position:relative;z-index:1}

  .feature{display:grid;grid-template-columns:1.05fr .95fr;align-items:stretch;position:relative;z-index:1}
  .feature-art{position:relative;min-height:520px;background:#2a211a;overflow:hidden}
  .feature-art img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform .7s ease}
  .feature:hover .feature-art img{transform:scale(1.04)}
  .feature-art::after{content:"";position:absolute;inset:14px;border:1px solid rgba(243,236,220,.5);pointer-events:none;transition:inset .45s ease}
  .feature:hover .feature-art::after{inset:22px}
  .feature-text{padding:64px 56px;background:var(--paper-2);display:flex;flex-direction:column}
  .feature-running{display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--line);padding-bottom:12px;margin-bottom:24px}
  .feature-cat{color:var(--red)}
  .feature-title{font-weight:700;font-size:clamp(2rem,3.4vw,3rem);line-height:1.06;margin:.25em 0 .55em;color:var(--ink)}
  .feature-body{font-size:1.06rem;color:var(--ink-soft);max-width:54ch}
  .feature-body p:first-of-type::first-letter{font-family:var(--display);font-weight:800;float:left;font-size:3.6rem;line-height:.78;padding:.06em .12em 0 0;color:var(--red)}
  .meta{font-family:var(--sans);font-size:.76rem;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-mute);margin:1.4em 0 1.6em}
  .meta b{color:var(--ink)}
  .feature-pull{margin-top:30px;padding-top:22px;border-top:1px solid var(--line);font-style:italic;font-size:1.3rem;line-height:1.3;color:var(--ink)}

  .archive{padding:88px 32px}
  .sec-head{display:flex;align-items:center;gap:20px;margin-bottom:46px}
  .chip--head{width:54px;height:54px;border:1px solid var(--red-deep)}
  .sec-title{font-weight:700;font-size:clamp(1.8rem,3vw,2.6rem);line-height:1;color:var(--ink)}
  .sec-head .rule-motif{flex:1}
  .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:52px 38px}
  .card{display:flex;flex-direction:column;transition:transform .3s ease}
  .card:hover{transform:translateY(-6px)}
  .card-img{position:relative;aspect-ratio:4/3;overflow:hidden;background:#2a211a;border:1px solid var(--ink);transition:box-shadow .35s ease}
  .card:hover .card-img{box-shadow:0 20px 32px -20px rgba(30,24,19,.5)}
  .card-img::after{content:"";position:absolute;inset:0;background:linear-gradient(to top, rgba(190,58,36,.22), transparent 55%);opacity:0;transition:opacity .4s ease;pointer-events:none}
  .card:hover .card-img::after{opacity:1}
  .card-img img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease, filter .5s ease}
  .card:hover .card-img img{transform:scale(1.05);filter:saturate(1.1)}
  .card-body{padding-top:18px}
  .card-cat{font-size:.66rem;color:var(--red)}
  .card-title{font-weight:600;font-size:1.55rem;line-height:1.1;margin:.28em 0 .2em;color:var(--ink);transition:color .25s}
  .card:hover .card-title{color:var(--red)}
  .card-sub{font-size:.96rem;color:var(--ink-soft);margin-bottom:1em}
  .card-meta{display:flex;align-items:center;gap:9px;border-top:1px solid var(--line);padding-top:12px}
  .diamond{width:6px;height:6px;transform:rotate(45deg);background:var(--marigold);flex:0 0 auto;transition:transform .45s ease, background .3s}
  .card:hover .diamond{transform:rotate(225deg);background:var(--red)}
  .archive-more{text-align:center;margin-top:60px}

  .cta{position:relative;z-index:1;background:#C24A1E url("/images/banner-warli.png") center/cover no-repeat;text-align:center}
  .cta::before{content:"";position:absolute;inset:0;background:rgba(40,18,8,.34)}
  .cta-inner{position:relative;z-index:1;padding:104px 32px;max-width:680px}
  .cta-kicker{color:#FCE3B0}
  .cta-title{font-weight:700;color:#FFF6E6;font-size:clamp(2.2rem,4.4vw,3.4rem);line-height:1.05;margin:.3em 0 .4em;text-shadow:0 2px 18px rgba(40,18,8,.4)}
  .cta-dek{color:#FBEACF;max-width:480px;margin:0 auto 2em;font-size:1.08rem}
  .cta-btn{border-color:#FCE3B0;color:#FFF6E6}
  .cta-btn:hover{background:#FCE3B0;color:#7a2a10}

  @media(max-width:960px){
    .cover{grid-template-columns:1fr;gap:40px;padding-top:48px}
    .cover-art{order:-1}
    .feature{grid-template-columns:1fr}
    .feature-art{min-height:340px}
    .feature-text{padding:44px 30px}
    .grid{grid-template-columns:repeat(2,1fr);gap:40px 28px}
  }
  @media(max-width:560px){
    .grid{grid-template-columns:1fr}
    .masthead{font-size:3.2rem}
  }
</style>
