---
import Layout from '../layouts/Layout.astro';

const stories = [
  { t: 'Dhoori', d: 'A Singapore–India travel mystery.' },
  { t: "Mama's Boy", d: 'A Singapore HDB horror short.' },
  { t: 'Classroom Warfare', d: 'Chapter 1 of a Singapore school mystery.' },
];
const data = [
  { t: 'Diabetes Readmission Risk Scores', d: 'ML models predicting hospital readmissions for diabetic patients at discharge.' },
  { t: 'Coffeeshop Sales Analysis', d: 'Analysing coffeeshop sales data to optimise profits.' },
  { t: 'HDB Price Prediction', d: 'How six key factors shape HDB resale price.' },
];
const articles = [
  { t: 'The Freedom of Exclusion', d: 'Singapore cultural identity in Eating Air (1999).' },
  { t: 'The Eye of the Beholder', d: 'Depictions of Bhakti in Pichvai art.' },
  { t: 'Unity in Diversity', d: "The Carnivalesque in Midnight's Children." },
];
---

<Layout title="Ram Jeevan Vinod — Writer & Data Analyst" description="Short fiction, data projects, and essays by Ram Jeevan Vinod, a Singapore writer and data analyst." bare={true}>

  <header class="pf-bar">
    <div class="pf-bar-inner">
      <a href="/" class="pf-logo">Ram Jeevan</a>
      <nav class="pf-nav">
        <a href="/portfolio" class="active">Portfolio</a>
        <a href="#about" class="hide-sm">About</a>
        <a href="/blog" class="hide-sm">Essays</a>
        <a href="/fiction" class="hide-sm">Fiction</a>
      </nav>
    </div>
  </header>

  <section class="pf-hero">
    <div class="pf-wrap">
      <span class="pf-eyebrow">Writer &amp; Data Analyst · Singapore</span>
      <h1 class="pf-serif">Storytelling with Data</h1>
      <p>Paying attention, listening, and experiencing life are essential to a storytelling instinct. Data analytics is a natural extension of that practice — a way to expand the range of the stories I can tell.</p>
      <a href="#projects" class="pf-btn pf-btn--solid">Explore my work <span>→</span></a>
      <div class="pf-scrolldot">Projects below ↓</div>
    </div>
  </section>

  <section id="projects" class="pf-projects">
    <div class="pf-proj-head">
      <span class="pf-eyebrow">Selected Work</span>
      <h2 class="pf-serif">Projects</h2>
    </div>
    <div class="pf-cols">
      <div class="pf-col pf-col--stories">
        <h3 class="pf-serif">Short Stories</h3>
        <span class="pf-kicker">Fiction rooted in Singapore</span>
        {stories.map((s) => (
          <a class="pf-card" href="#"><h4 class="pf-serif">{s.t}</h4><p>{s.d}</p><span class="pf-go">Read →</span></a>
        ))}
      </div>
      <div class="pf-col pf-col--data">
        <h3 class="pf-serif">Data Analytics</h3>
        <span class="pf-kicker">Machine learning &amp; analysis</span>
        {data.map((s) => (
          <a class="pf-card" href="#"><h4 class="pf-serif">{s.t}</h4><p>{s.d}</p><span class="pf-go">View →</span></a>
        ))}
      </div>
      <div class="pf-col pf-col--articles">
        <h3 class="pf-serif">Articles</h3>
        <span class="pf-kicker">Criticism &amp; cultural essays</span>
        {articles.map((s) => (
          <a class="pf-card" href="#"><h4 class="pf-serif">{s.t}</h4><p>{s.d}</p><span class="pf-go">Read →</span></a>
        ))}
      </div>
    </div>
  </section>

  <section id="about" class="pf-about">
    <div class="pf-wrap pf-about-grid">
      <figure class="pf-portrait"><img src="/images/About_Image.jpg" alt="Ram Jeevan Vinod, Singapore writer and data analyst" /></figure>
      <div>
        <span class="pf-eyebrow">About</span>
        <h2 class="pf-serif">About Me</h2>
        <p>One of my hobbies is learning about the relationship between ancient Indian art — paintings, instruments, architecture — and Hindu philosophical teachings. I also write stories rooted in Singaporean culture, drawing from my own experience.</p>
        <p>Outside of that, I am constantly learning about data and AI as I grow as an analyst.</p>
        <a href="/blog" class="pf-btn">Read the essays <span>→</span></a>
      </div>
    </div>
  </section>

  <footer class="pf-footer">
    <div class="pf-foot">
      <div>
        <a href="/" class="pf-logo pf-serif pf-foot-logo">Ram Jeevan</a>
        <p>Writer and data analyst based in Singapore — short fiction, data projects, and essays on art and culture.</p>
      </div>
      <div class="pf-links">
        <a href="#projects">Portfolio</a>
        <a href="#about">About</a>
        <a href="/blog">Essays</a>
        <a href="/fiction">Fiction</a>
        <a href="#">Instagram</a>
      </div>
    </div>
    <div class="pf-foot-bar">© 2026 Ram Jeevan Vinod · Singapore</div>
  </footer>

</Layout>

<style is:global>
  /* Portfolio keeps its own warm-gradient identity (self-contained) */
  body{ background:#E8DCC8; color:#3A2A1E; font-family:"Karla",system-ui,sans-serif; }
  .pf-serif{font-family:"Cormorant Garamond",Georgia,serif}
  .pf-wrap{max-width:1240px;margin:0 auto;padding:0 32px;position:relative;z-index:1}
  .pf-eyebrow{font-family:"Karla",sans-serif;font-weight:700;letter-spacing:.28em;text-transform:uppercase;font-size:.72rem;color:#9C5A3C}
  .pf-btn{display:inline-flex;align-items:center;gap:.6em;font-family:"Karla",sans-serif;font-weight:700;letter-spacing:.18em;text-transform:uppercase;font-size:.72rem;padding:.9em 1.9em;border:1px solid #9C5A3C;color:#9C5A3C;background:transparent;cursor:pointer;transition:all .25s}
  .pf-btn:hover{background:#9C5A3C;color:#fff}
  .pf-btn--solid{background:#9C5A3C;color:#fff8ef}
  .pf-btn--solid:hover{background:#864A30;border-color:#864A30}

  .pf-bar{position:sticky;top:0;z-index:20;background:rgba(232,220,200,.9);backdrop-filter:blur(8px);border-bottom:1px solid #C9B89B}
  .pf-bar-inner{max-width:1240px;margin:0 auto;padding:18px 32px;display:flex;align-items:center;justify-content:space-between}
  .pf-logo{font-family:"Cormorant Garamond",serif;font-style:italic;font-size:1.7rem;font-weight:500;color:#3A2A1E}
  .pf-nav{display:flex;align-items:center;gap:30px}
  .pf-nav a{font-weight:600;font-size:.82rem;letter-spacing:.06em;text-transform:uppercase;color:#5C4A3B;transition:color .2s}
  .pf-nav a:hover,.pf-nav a.active{color:#9C5A3C}

  .pf-hero{position:relative;text-align:center;padding:120px 0 130px;overflow:hidden;background:radial-gradient(120% 90% at 50% 0%, #F6DCBE 0%, #EFD3B4 28%, #E8DCC8 64%, #E4D6BE 100%)}
  .pf-hero .pf-wrap{max-width:760px}
  .pf-hero h1{font-family:"Cormorant Garamond",serif;font-weight:500;font-size:clamp(2.8rem,6vw,5rem);line-height:1.02;margin:.32em 0 .5em;color:#3A2A1E}
  .pf-hero p{font-size:1.16rem;color:#5C4A3B;max-width:600px;margin:0 auto 2.2em}
  .pf-scrolldot{margin-top:60px;font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;color:#5C4A3B;opacity:.7}

  .pf-proj-head{text-align:center;padding:84px 0 10px}
  .pf-proj-head .pf-eyebrow{display:block;margin-bottom:.6em}
  .pf-proj-head h2{font-family:"Cormorant Garamond",serif;font-weight:500;font-size:clamp(2rem,3.4vw,2.8rem);color:#3A2A1E}
  .pf-cols{display:grid;grid-template-columns:repeat(3,1fr);gap:0}
  .pf-col{padding:64px 40px 72px;min-height:520px}
  .pf-col--stories{background:linear-gradient(170deg,#557C78 0%,#3F5F5C 100%)}
  .pf-col--data{background:linear-gradient(170deg,#A4643F 0%,#834A2E 100%)}
  .pf-col--articles{background:linear-gradient(170deg,#C29A55 0%,#A07E3C 100%)}
  .pf-col h3{font-family:"Cormorant Garamond",serif;font-weight:600;font-size:1.9rem;color:#fdf6ea;text-align:center;margin-bottom:8px}
  .pf-col .pf-kicker{display:block;text-align:center;font-size:.68rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:30px}
  .pf-card{background:rgba(255,251,244,.94);border:1px solid rgba(255,255,255,.4);padding:22px 22px 20px;margin-bottom:18px;transition:transform .25s, box-shadow .25s;display:block}
  .pf-card:hover{transform:translateY(-4px);box-shadow:0 20px 36px -22px rgba(20,12,6,.55)}
  .pf-card h4{font-family:"Cormorant Garamond",serif;font-weight:600;font-size:1.4rem;line-height:1.12;color:#3A2A1E;margin-bottom:.25em}
  .pf-card p{font-size:.9rem;color:#5C4A3B;margin-bottom:.7em}
  .pf-card .pf-go{font-size:.68rem;letter-spacing:.16em;text-transform:uppercase;font-weight:700;color:#9C5A3C}
  .pf-col--stories .pf-card .pf-go{color:#3F5F5C}
  .pf-col--articles .pf-card .pf-go{color:#8a6a2c}

  .pf-about{background:#EFE6D4;padding:104px 0}
  .pf-about-grid{display:grid;grid-template-columns:.8fr 1.2fr;gap:64px;align-items:center}
  .pf-portrait{aspect-ratio:4/5;border:1px solid #C9B89B;overflow:hidden;background:#E8DCC8}
  .pf-portrait img{width:100%;height:100%;object-fit:cover;object-position:center 20%;display:block}
  .pf-about h2{font-family:"Cormorant Garamond",serif;font-weight:500;font-size:clamp(2rem,3.4vw,2.9rem);color:#3A2A1E;margin:.2em 0 .5em}
  .pf-about p{font-size:1.06rem;color:#5C4A3B;margin-bottom:1.2em;max-width:560px}

  .pf-footer{background:#241B14;color:#E8DCC8}
  .pf-foot{max-width:1240px;margin:0 auto;padding:72px 32px 40px;display:grid;grid-template-columns:1.4fr 1fr;gap:40px;align-items:start}
  .pf-foot-logo{color:#F4ECDC;font-size:2rem;margin-bottom:.5em;display:inline-block}
  .pf-foot p{color:#b8a78c;max-width:420px;font-size:.96rem}
  .pf-links{display:flex;flex-direction:column;gap:12px}
  .pf-links a{color:#E8DCC8;font-size:.82rem;letter-spacing:.08em;text-transform:uppercase;font-weight:600;transition:color .2s}
  .pf-links a:hover{color:#E2A878}
  .pf-foot-bar{border-top:1px solid rgba(201,184,155,.18);text-align:center;padding:22px;font-size:.74rem;letter-spacing:.1em;text-transform:uppercase;color:#8a7860}

  @media(max-width:920px){
    .pf-cols{grid-template-columns:1fr}
    .pf-col{min-height:0}
    .pf-about-grid{grid-template-columns:1fr;gap:36px}
    .pf-portrait{max-width:260px}
    .pf-foot{grid-template-columns:1fr}
  }
  @media(max-width:600px){
    .pf-nav{gap:16px}
    .pf-nav a.hide-sm{display:none}
    .pf-hero{padding:80px 0 90px}
  }
</style>
